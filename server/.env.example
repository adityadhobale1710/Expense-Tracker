# Core Server Configuration
NODE_ENV=production
PORT=5000
MONGO_URI=<MongoDB Atlas connection string with database name>

# Security & Authentication Tokens
JWT_SECRET=<secure random secret>
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=<secure random secret>
JWT_REFRESH_EXPIRE=7d
COOKIE_SECRET=<secure random secret>
CLIENT_URL=<Frontend URL e.g. http://localhost:5173>

# Optional: Real SMTP Email Delivery (Console logging fallback is used if omitted)
# SMTP_HOST=<SMTP host>
# SMTP_PORT=<SMTP port e.g. 587 or 2525>
# SMTP_USER=<SMTP username>
# SMTP_PASS=<SMTP password>
# SMTP_FROM=<sender email>
# SMTP_FROM_NAME=<application name>
